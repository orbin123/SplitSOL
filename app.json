{
  "expo": {
    "name": "SplitSOL",
    "slug": "splitsol",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/splitsol-icon1.png",
    "userInterfaceStyle": "light",
    "scheme": "splitsol",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E1A"
      },
      "package": "com.splitsol.app",
      "permissions": [
        "CAMERA",
        "VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "SplitSOL needs camera access to scan QR codes for adding wallet addresses."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F8F7FC",
          "image": "./assets/icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "08ef1b5f-5816-4a89-ad9d-8599dce285ae"
      }
    },
    "owner": "orbin790"
  }
}
